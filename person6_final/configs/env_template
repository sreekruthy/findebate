# evaluation_project/.env
# Copy this file to the evaluation_project/ directory and fill in your keys

# ── Required: Gemini (Google AI Studio - FREE) ────────────────────────────────
# Get your free key at: https://aistudio.google.com/app/apikey
# Free tier: 15 RPM, 1500 RPD for gemini-2.0-flash
GEMINI_API_KEY=your_gemini_api_key_here

# ── Required for cross-model benchmark: OpenRouter (FREE tier) ────────────────
# Get your free key at: https://openrouter.ai/
# Free models available: llama-4-maverick:free, deepseek-r1:free, claude-sonnet-4-5:free
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Optional: tuning ─────────────────────────────────────────────────────────
SLEEP_BETWEEN_CALLS=4.0      # seconds between Gemini calls (free tier: 15 RPM = 4s safe)
SLEEP_GEMINI=5.0
SLEEP_OPENROUTER=3.0
MAX_RETRIES=3

# ── Paths (defaults are fine for standard layout) ─────────────────────────────
OUTPUT_FOLDER=outputs
RESULTS_CSV=outputs/llm_judge/llm_judge_results.csv
BENCHMARK_OUTPUT_DIR=outputs/cross_model
JUDGE_RESULTS_DIR=outputs/stats
FINAL_STATS_OUTPUT=outputs/stats/final_statistics.json
CHARTS_DIR=charts

# ── Batch control (set by SLURM array, or override manually) ─────────────────
BATCH_START=0
BATCH_END=999
